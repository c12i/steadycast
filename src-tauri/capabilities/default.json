{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Steadycast",
  "windows": ["main", "stream-preview", "ffmpeg-logs"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-kill",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "dialog:allow-open"
  ]
}
